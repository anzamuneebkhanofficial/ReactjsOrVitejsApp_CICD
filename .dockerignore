# =====================================================================
# .dockerignore — Files excluded from the Docker build context
# =====================================================================
# Keep this file in sync with .gitignore

# Dependencies (will be reinstalled inside the container)
node_modules

# Vite build output (rebuilt inside the container)
dist

# Environment variable files — NEVER bake secrets into images
.env
.env.local
.env.development
.env.production
.env*.local

# Git internals
.git
.gitignore
.gitattributes

# Editor & IDE configs
.vscode
.idea
*.swp
*.swo

# OS-generated files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing & coverage
coverage
.nyc_output
__tests__
*.test.*
*.spec.*

# CI/CD
.github

# Docker files themselves (no need to COPY into image)
Dockerfile
docker-compose.yml
.dockerignore

# Docs / markdown (optional)
README.md