# =====================================================================
# .gitignore — Files excluded from Git tracking
# =====================================================================

# -------------------------------------------------------
# Next.js
# -------------------------------------------------------
.next/
out/
.vercel


# -------------------------------------------------------
# Node dependencies
# -------------------------------------------------------
node_modules/

# -------------------------------------------------------
# Environment variables
# RULE: Only .env.example should ever be committed.
#       All actual .env files are private — never commit them.
# -------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env*.local

# -------------------------------------------------------
# Logs
# -------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------------------------------------------------------
# Testing & coverage
# -------------------------------------------------------
coverage/
.nyc_output/

# -------------------------------------------------------
# Build caches
# -------------------------------------------------------
.turbo/
.cache/
.eslintcache

# -------------------------------------------------------
# Editor & IDE configs (optional — keep if team uses them)
# -------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# -------------------------------------------------------
# OS-generated files
# -------------------------------------------------------
.DS_Store
Thumbs.db
.vercel
