# =====================================================================
# .env.example — Template for environment variables
# =====================================================================
# ✅ This file IS committed to Git.
# ❌ The actual .env file is NOT committed (see .gitignore).
#
# HOW TO USE:
#   cp .env.example .env
#   # Then fill in your real values in .env
# =====================================================================

# -------------------------------------------------------
# Application
# -------------------------------------------------------
NODE_ENV=development
PORT=3000

# -------------------------------------------------------
# Next.js Public Variables (exposed to the browser)
# Prefix with NEXT_PUBLIC_ to make them accessible client-side.
# -------------------------------------------------------
NEXT_PUBLIC_APP_NAME=My Next.js App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------------------
# Server-side API secrets (NOT exposed to the browser)
# -------------------------------------------------------
# Your backend API base URL (e.g., Express, FastAPI, Django, etc.)
API_BASE_URL=http://localhost:5000

# -------------------------------------------------------
# Telemetry
# -------------------------------------------------------
NEXT_TELEMETRY_DISABLED=1
